---
import ImgComp from "@/features/base/ImgComp.astro";
import websiteSetting from "@/features/websiteSetting.json";
import NavBarSide from "./NavBarSide.astro";
import ActionBtn from "@/features/base/ActionBtn.astro";

type MenuItem = {
  label: string;
  link: string;
};

type NavBar = {
  label: string;
  link: string;
  type: "single" | "dropdown";
  subNav?: MenuItem[];
};

const {
  logoSrc = websiteSetting.websiteLogo1.image,
  menuItems = websiteSetting.NavbarInsertion,
  leftImg = {
    src: "",
    alt: "",
  },
} = Astro.props;
---

<div
  class="navbar bg-base-100 backdrop-blur-md px-6 md:px-12 lg:px-16 z-50 shadow-md shadow-base-200 border-b border-base-content/10"
>
  <div class="navbar-start">
    <a href="/">
      <ImgComp img={logoSrc} height={48} class="h-12" />
    </a>
  </div>
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal gap-2 px-4">
      {
        menuItems.map((item: NavBar) => (
          <li>
            {item.type === "dropdown" && item.subNav ? (
              <details>
                <summary class="text-base-content">{item.label}</summary>
                <ul class="p-2 bg-base-100">
                  {item.subNav.map((subItem) => (
                    <li>
                      <a href={subItem.link} class="text-base-content">
                        {subItem.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a href={item.link} class="text-base-content">
                {item.label}
              </a>
            )}
          </li>
        ))
      }
    </ul>
  </div>
  <div class="navbar-end">
    <NavBarSide />
    {
      websiteSetting.ctaLink.label !== "" && (
        <div class="hidden lg:block">
          <ActionBtn
            ctaText={websiteSetting.ctaLink.label}
            ctaLink={websiteSetting.ctaLink.link}
          />
        </div>
      )
    }
    <button
      class="btn btn-ghost lg:hidden"
      id="mobile-menu-btn"
      aria-label="Toggle menu"
    >
      <svg
        class="h-6 w-6 stroke-base-content fill-base-content"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</div>

<div id="mobile-menu" class="fixed inset-0 z-9999 hidden">
  <div
    class="menuContent bg-base-100 h-screen w-full transform -translate-x-full transition-transform duration-300 ease-in-out"
  >
    <div class="flex h-full w-full">
      <div
        class="w-full lg:w-1/2 flex flex-col gap-10 justify-start h-full p-10"
      >
        <div class="px-6 flex items-center justify-between">
          <div>
            <ImgComp img={logoSrc} height={48} class="h-12" />
          </div>
          <button
            class="btn btn-square btn-ghost btn-sm"
            id="mobile-menu-close"
            aria-label="Close menu"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-10 stroke-base-content fill-base-content"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <ul class="menu">
          {
            menuItems.map((item: NavBar) => (
              <li class="w-full">
                {item.type === "dropdown" && item.subNav ? (
                  <details>
                    <summary class="text-3xl lg:text-5xl font-bold text-base-content">
                      {item.label}
                    </summary>
                    <ul class="p-2">
                      {item.subNav.map((subItem) => (
                        <li>
                          <a
                            href={subItem.link}
                            class="text-2xl lg:text-3xl font-bold text-base-content"
                          >
                            {subItem.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                ) : (
                  <a
                    href={item.link}
                    class="text-3xl lg:text-5xl font-bold text-base-content"
                  >
                    {item.label}
                  </a>
                )}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="hidden lg:block w-full lg:w-1/2 h-full">
        <ImgComp
          img={leftImg}
          layout="constrained"
          width={2560}
          height={1440}
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </div>
</div>

<script>
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileMenuClose = document.getElementById("mobile-menu-close");
  const menuContent = mobileMenu?.querySelector(".menuContent");

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.remove("hidden");
    setTimeout(() => {
      menuContent?.classList.remove("-translate-x-full");
      menuContent?.classList.add("translate-x-0");
    }, 10);
  });

  mobileMenuClose?.addEventListener("click", () => {
    menuContent?.classList.add("-translate-x-full");
    menuContent?.classList.remove("translate-x-0");
    setTimeout(() => {
      mobileMenu?.classList.add("hidden");
    }, 300);
  });

  mobileMenu
    ?.querySelector(".drawer-overlay")
    ?.addEventListener("click", () => {
      menuContent?.classList.add("-translate-x-full");
      menuContent?.classList.remove("translate-x-0");
      setTimeout(() => {
        mobileMenu?.classList.add("hidden");
      }, 300);
    });
</script>
